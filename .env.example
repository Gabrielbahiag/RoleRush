# Copie para .env (ou exporte no shell) e preencha os valores.
# Nunca commitar o .env de verdade — ele já está no .gitignore.

# Token do bot do Telegram, obtido com o @BotFather.
TELEGRAM_BOT_TOKEN=

# Chat ID para onde as notificações serão enviadas (seu chat com o bot,
# ou o id de um grupo/canal).
TELEGRAM_CHAT_ID=

# Opcional, só pra rodar localmente: token de acesso pessoal do GitHub,
# aumenta o rate limit da API (60 -> 5000 req/h) ao ler issues de
# repositórios de vagas. No GitHub Actions isso não é necessário — o
# workflow já usa o GITHUB_TOKEN que o próprio Actions injeta sozinho.
GITHUB_TOKEN=
